{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "Harmony Wedding Rental",
	"version": "0.1.1",
	"identifier": "com.harmony.weddingrental",
	"build": {
		"frontendDist": "../dist/client",
		"devUrl": "http://localhost:3000",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "(bun run scripts/tauri-prebuild.ts || bun run ../scripts/tauri-prebuild.ts) && bun run build && (bun run scripts/tauri-postbuild.ts || bun run ../scripts/tauri-postbuild.ts)"
	},
	"app": {
		"windows": [
			{
				"title": "Harmony Wedding Rental",
				"width": 1440,
				"height": 900,
				"minWidth": 1100,
				"minHeight": 720,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"resources": [
			"resources/*"
		],
		"externalBin": [
			"bin/bun"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
