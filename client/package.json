		"apollo-upload-client": "^19.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"graphql": "^16.13.1",
		"graphql-sse": "^2.6.0",
		"graphql-ws": "^6.0.7",
		"lucide-react": "^0.577.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.0",
