{
	"name": "client",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"tauri:dev": "env HARMONY_RUST_TOOLCHAIN=stable CARGO=$(pwd)/tauri-toolchain/bin/cargo RUSTC=$(pwd)/tauri-toolchain/bin/rustc PATH=$(pwd)/tauri-toolchain/bin:$PATH tauri dev",
		"tauri:build": "env HARMONY_RUST_TOOLCHAIN=stable CARGO=$(pwd)/tauri-toolchain/bin/cargo RUSTC=$(pwd)/tauri-toolchain/bin/rustc PATH=$(pwd)/tauri-toolchain/bin:$PATH tauri build",
		"test": "vitest run",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"codegen": "graphql-codegen --config codegen.ts && bunx --bun @biomejs/biome check --write src/gql/"
	},
	"dependencies": {
		"@apollo/client": "^4.1.6",
		"@base-ui/react": "^1.2.0",
